APP_NAME="EM Backend"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=stderr
LOG_LEVEL=info

# External database (e.g. Render Postgres) — no DB service in docker-compose
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=require

# Set true on first deploy to run migrations, then false
RUN_MIGRATIONS=false

# Frontend origin for CORS (comma-separated if multiple)
FRONTEND_URL=http://localhost:5173

PORT=8000
