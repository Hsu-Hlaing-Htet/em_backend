APP_NAME="EM Backend"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Neon / external Postgres — paste the full connection string from Neon dashboard
DB_CONNECTION=pgsql
DB_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Set true on first deploy to run migrations, then false
RUN_MIGRATIONS=false

# Frontend origin for CORS (comma-separated if multiple)
FRONTEND_URL=http://localhost:5173

PORT=8000
